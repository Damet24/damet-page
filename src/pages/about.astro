---
import MainLayout from '../layouts/MainLayout.astro';
import TerminalButton from '../components/TerminalButton.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import { AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const EXPERIENCE = [
	{
		date: 'Jul. 2023 - Ago. 2024 · 1 año y 2 meses',
		title: 'Software Developer',
		company: 'Masivian',
		description:
			'Desarrollé soluciones de backend con .NET y AWS, proporcionando soporte y resolviendo bugs para un sistema de envío de correos masivo, utilizando diversas bases de datos como Redis, MongoDB, DynamoDB y Redshift, para asegurar la disponibilidad y escalabilidad del sistema.',
		link: 'https://www.linkedin.com/company/masivian/mycompany/',
	},
	{
		date: 'Jul. 2021 - Nov. 2022 · 1 año 5 meses',
		title: 'Fullstack Web Developer',
		company: 'Colombian Teknologies SAS',
		description:
			'Desarrollé aplicaciones a medida para diversos clientes, manejando tanto el desarrollo backend como frontend. Utilicé una variedad de tecnologías, incluyendo React, PHP y JavaScript, adaptándome a las necesidades específicas de cada proyecto, para garantizar una experiencia de usuario óptima y soluciones escalables.',
		link: 'https://www.linkedin.com/in/damet24/',
	},
];
---

<MainLayout title={`${SITE_TITLE} — about`} description={SITE_DESCRIPTION}>

<section>
	<p class="font-mono text-sm text-green-400/60">
		<span class="text-green-400">$</span> cat /home/{AUTHOR.toLowerCase().replace(' ', '-')}/README.md
	</p>

	<h1 class="font-mono text-2xl font-semibold text-green-300 sm:text-3xl md:text-4xl">
		<span class="text-green-400/50">></span> sobre mí
	</h1>

	<div class="mt-8 flex flex-col gap-8 md:flex-row md:gap-12">
		<div class="space-y-5 font-mono text-base leading-relaxed text-green-400/70 flex-1">
			<p>
				<strong class="text-green-300">Software Developer</strong> de Bogotá, Colombia 🇨🇴.
				Especializado en soluciones escalables con <strong class="text-green-300">.NET (C#)</strong> y <strong class="text-green-300">Node.js</strong>. Con experiencia en arquitecturas <strong class="text-green-300">AWS</strong>, principios <strong class="text-green-300">SOLID</strong> y desarrollo de sistemas de alto rendimiento.
			</p>

			<p>
				Inicié mi camino como <strong class="text-green-300">autodidacta en programación</strong> desde la escuela. Tras un año explorando la música, comencé mi trayectoria como desarrollador de software profesionalmente.
			</p>

			<p>
				Actualmente curso la carrera de <strong class="text-green-300">Ingeniería Informática</strong>, combinando mi formación académica con la experiencia práctica para seguir fortaleciendo mis habilidades en el desarrollo de soluciones modernas, seguras y de alta calidad.
			</p>

			<p>
				Este blog es mi cuaderno de bitácora. Aquí voy a dejar notas técnicas, writeups de máquinas, configuraciones, y cualquier cosa que valga la pena recordar.
			</p>
		</div>

		<img
			src="/me.webp"
			alt="Daniel Mercado"
			class="size-48 shrink-0 rounded-2xl border border-green-500/30 object-cover shadow-lg shadow-green-500/5 md:size-56"
		/>
	</div>

	<div class="mt-8 flex flex-wrap gap-3">
		<TerminalButton href="https://github.com/damet24" external>github</TerminalButton>
		<TerminalButton href="mailto:daniel.mercado.dev@gmail.com" external>email</TerminalButton>
		<TerminalButton href="https://linkedin.com/in/Damet24" external>linkedin</TerminalButton>
	</div>
</section>

<section class="mt-16 border-t border-green-500/10 pt-12">
	<p class="font-mono text-sm text-green-400/60">
		<span class="text-green-400">$</span> cat /var/log/syslog | grep "experience"
	</p>

	<h2 class="mt-1 font-mono text-xl font-semibold text-green-300 sm:text-2xl">
		<span class="text-green-400/50">></span> experiencia
	</h2>

	<ol class="mt-8 flex flex-col gap-4 list-none">
		{EXPERIENCE.map((exp) => (
			<li class="list-none"><ExperienceItem {...exp} /></li>
		))}
	</ol>
</section>

</MainLayout>