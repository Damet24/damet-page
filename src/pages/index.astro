---
import MainLayout from '../layouts/MainLayout.astro';
import TerminalButton from '../components/TerminalButton.astro';
import StatusTerminal from '../components/StatusTerminal.astro';
import { projects } from '../data/projects';
import { AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>

<section class="mt-8 md:mt-16 lg:mt-20">
	<div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:gap-16">

		<div class="min-w-0 flex-1 space-y-6">
			<p class="font-mono text-sm text-green-400/60">
				<span class="text-green-400">$</span> cat README.md
			</p>

			<h1 class="font-mono text-3xl font-semibold leading-tight text-green-300 sm:text-4xl md:text-5xl">
				<span class="text-green-400/50">></span> {AUTHOR}
			</h1>

			<p class="font-mono text-base leading-relaxed text-green-400/70 md:text-lg">
				Hola, soy Daniel. Me gusta la tecnología y la programación.
				Estoy en mi camino para convertirme en <span class="text-green-300">hacker</span> y en este espacio comparto mi proceso.
			</p>

			<div class="flex flex-wrap gap-3 pt-2">
				<TerminalButton href="/blog">./leer-notas</TerminalButton>
				<TerminalButton href="https://github.com/damet24" external>github</TerminalButton>
			</div>
		</div>

		<div class="w-full shrink-0 lg:w-96">
			<StatusTerminal />
		</div>

	</div>
</section>

<section class="mt-16 border-t border-green-500/10 pt-12 md:mt-24 md:pt-16">
	<p class="font-mono text-sm text-green-400/60">
		<span class="text-green-400">$</span> ls -l /builds/ | head -3
	</p>

	<div class="mt-1 flex items-baseline gap-3">
		<h2 class="font-mono text-xl font-semibold text-green-300 sm:text-2xl">
			<span class="text-green-400/50">></span> builds destacadas
		</h2>
		<a href="/projects" class="font-mono text-xs text-green-400/40 hover:text-green-400 transition-colors">[ver todas]</a>
	</div>

	<div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
		{projects.slice(0, 3).map((p) => (
			<div class="rounded-xl border border-green-500/20 bg-green-500/[0.03] p-4 transition-colors hover:border-green-500/40">
				<h3 class="font-mono text-sm font-semibold text-green-300">
					<a href={p.link} class="hover:underline">{p.title}</a>
				</h3>
				<p class="mt-1.5 font-mono text-sm leading-relaxed text-green-400/60 line-clamp-2">
					{p.description}
				</p>
				<div class="mt-2.5 flex flex-wrap gap-1.5">
					{p.tags.map((tag) => (
						<span class={`rounded px-2 py-0.5 font-mono text-[11px] ${tag.class}`}>{tag.name}</span>
					))}
				</div>
			</div>
		))}
	</div>
</section>

<section class="mt-12 border-t border-green-500/10 pt-12 md:mt-16 md:pt-16">
	<p class="font-mono text-sm text-green-400/60">
		<span class="text-green-400">$</span> whoami
	</p>

	<h2 class="mt-1 font-mono text-xl font-semibold text-green-300 sm:text-2xl">
		<span class="text-green-400/50">></span> {AUTHOR}
	</h2>

	<p class="mt-3 max-w-prose font-mono text-base leading-relaxed text-green-400/70">
		Tecnología, programación y seguridad ofensiva.
		Este es mi espacio para documentar el proceso.
	</p>

	<div class="mt-4">
		<TerminalButton href="/about">./ver-perfil</TerminalButton>
	</div>
</section>

</MainLayout>
