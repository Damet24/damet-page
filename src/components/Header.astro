			<span class="text-green-400/50">:~$</span>
			<span class="animate-pulse text-green-400">_</span>
		</a>
		<div class="flex items-center gap-1">
			<HeaderLink href="/">/home</HeaderLink>
			<HeaderLink href="/projects">/projects</HeaderLink>
