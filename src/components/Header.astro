---
import HeaderLink from './HeaderLink.astro';
---

<header id="header" class="sticky top-0 z-50 py-3">
	<nav id="nav-dock" class="mx-auto flex w-full max-w-[1024px] items-center justify-between gap-6 rounded-2xl border border-green-500/30 bg-black/80 px-5 py-2 shadow-lg shadow-green-500/5 transition-all duration-300">
		<a href="/" class="flex items-center gap-1 text-green-400/70 hover:text-green-400 transition-colors whitespace-nowrap">
			<span class="text-green-400 font-semibold">visitor</span>
			<span class="text-green-400/50">@</span>
			<span class="text-green-400 font-semibold">daniel</span>
			<span class="text-green-400/50">:~$</span>
			<span class="animate-pulse text-green-400">_</span>
		</a>
		<div class="flex items-center gap-1">
			<HeaderLink href="/">/home</HeaderLink>
			<HeaderLink href="/projects">/projects</HeaderLink>
			<HeaderLink href="/blog">/blog</HeaderLink>
			<HeaderLink href="/about">/about</HeaderLink>
		</div>
	</nav>
</header>

<style>
	nav[data-scrolled="true"] {
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}
</style>

<script>
	const nav = document.getElementById('nav-dock');
	let ticking = false;

	window.addEventListener('scroll', () => {
		if (!ticking) {
			requestAnimationFrame(() => {
				nav.dataset.scrolled = window.scrollY > 50 ? 'true' : 'false';
				ticking = false;
			});
			ticking = true;
		}
	});
</script>