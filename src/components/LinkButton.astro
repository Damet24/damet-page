---
interface Props {
	href: string;
}

const { href } = Astro.props;
---

<a
	href={href}
	target="_blank"
	rel="noopener noreferrer"
	class="inline-flex items-center gap-2 rounded-lg border border-green-500/30 bg-green-500/5 px-4 py-2 font-mono text-xs text-green-400/80 transition-all hover:bg-green-500/10 hover:border-green-400/50 hover:text-green-300"
>
	<slot />
</a>
